NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Security — rate limiting and external CORS are handled by MuleSoft API Gateway
MULESOFT_ORIGIN=http://mulesoft-gateway:8080

# External APIs (example)
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=your-api-key-here
