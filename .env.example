NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Security — rate limiting and external CORS are handled by MuleSoft API Gateway
MULESOFT_ORIGIN=http://mulesoft-gateway:8080

# External APIs (example)
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=your-api-key-here

# BCP API
BCP_BASE_URL=https://bcp.corp.com
BCP_API_KEY=your-bcp-api-key-here

# Salesforce Personalization (Marketing Cloud Personalization / Interaction Studio)
SF_PERSONALIZATION_BASE_URL=https://your-tenant.us-1.evergage.com
SF_PERSONALIZATION_DATASET_ID=your-dataset-id
SF_PERSONALIZATION_CLIENT_ID=your-client-id
SF_PERSONALIZATION_CLIENT_SECRET=your-client-secret
# Default: https://login.salesforce.com/services/oauth2/token
SF_PERSONALIZATION_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
